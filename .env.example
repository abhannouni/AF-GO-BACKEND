# Environment Configuration
NODE_ENV=development
PORT=3000

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/mapproject
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/mapproject
MONGODB_URI_TEST=mongodb://localhost:27017/mapproject_test

# API Configuration
API_VERSION=v1

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long-and-random
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-jwt-key-different-from-access-token-secret
JWT_REFRESH_EXPIRES_IN=7d
JWT_COOKIE_EXPIRES_IN=604800000

# CORS Configuration (comma-separated list)
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:5173